{
  "name": "homeworld-rise-of-hiigara",
  "version": "0.61.0",
  "description": "A total conversion mod for Freelancer bringing the epic space warfare of Homeworld",
  "main": "index.html",
  "scripts": {
    "dev": "npx vite",
    "build": "npx vite build",
    "preview": "npx vite preview",
    "lint": "eslint js/ --fix && stylelint css/ --fix",
    "format": "prettier --write '**/*.{js,css,html,json}'",
    "serve": "npx http-server"
  },
  "keywords": [
    "homeworld",
    "mod",
    "freelancer",
    "space",
    "game",
    "conversion"
  ],
  "author": "Rise of Hiigara Team",
  "license": "NONFREE",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/homeworld-rise-of-hiigara"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-a11y": "^1.1.0",
    "prettier": "^3.0.0",
    "stylelint": "^15.0.0",
    "stylelint-config-prettier": "^9.0.0",
    "stylelint-config-standard": "^33.0.0",
    "vite": "^4.4.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
